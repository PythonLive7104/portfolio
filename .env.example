# Copy to .env next to docker-compose.yml. Compose loads this file automatically.
#
# Frontend (browser): use same-origin /api — nginx proxies to Django. Do NOT set :8000 or localhost here.
VITE_API_URL=/api

DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=your.server.ip,localhost,127.0.0.1

# Optional: DATABASE_ENGINE=sqlite
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_HOST=
POSTGRES_PORT=5432
