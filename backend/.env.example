# Copy to `backend/.env` (gitignored). Root `portfolio/.env` is loaded first; `backend/.env` overrides it.

DJANGO_DEBUG=true
# Required in production — must map to Django SECRET_KEY (empty → broken sessions / admin 500)
DJANGO_SECRET_KEY=change-me-in-production
# Every host or IP you open the site with (comma-separated). Omitting your server IP causes DisallowedHost.
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your.server.ip
# Optional: comma-separated, e.g. https://yourdomain.com — if unset, http://<each ALLOWED_HOST> is used
# DJANGO_CSRF_TRUSTED_ORIGINS=https://yourdomain.com
# Optional CORS for SPA (comma-separated)
# DJANGO_CORS_ORIGINS=http://your.server.ip,http://localhost:5173
#
# Media URLs in API: leave unset to use path-only /media/... (recommended when nginx serves /media/).
# Only set if uploads are on another origin (CDN):
# DJANGO_PUBLIC_BASE_URL=https://cdn.example.com
# DJANGO_MEDIA_USE_RELATIVE_URLS=true

# PostgreSQL — required. Create DB first for local Postgres, e.g.:
#   createuser -P portfolio
#   createdb -O portfolio portfolio
POSTGRES_DB=portfolio
POSTGRES_USER=portfolio
POSTGRES_PASSWORD=your_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# Managed/cloud Postgres (e.g. Aiven) often needs SSL:
# POSTGRES_SSLMODE=require
